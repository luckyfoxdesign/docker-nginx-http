# Режим nginx: http-nginx.conf (HTTP) или https-nginx.conf (HTTPS)
NGINX_CONF=http-nginx.conf

# Домены через пробел (первый используется для SSL-сертификата)
DOMAINS=example.com www.example.com

# Первый (основной) домен — используется в пути к сертификату certbot
PRIMARY_DOMAIN=example.com

# Email для Let's Encrypt уведомлений
LETSENCRYPT_EMAIL=admin@example.com

# Bearer-токен для защищённых API-эндпоинтов
# Сгенерировать сильный токен: openssl rand -hex 32
AUTH_TOKEN=Bearer your-secret-token-here
